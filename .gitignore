# Project spec — keep local, not in version control
instructions.txt

# ===== Vivado / FPGA build artifacts =====
*.bit
*.ltx
*.log
*.jou
*.pb
*.str
vivado_*
.Xil/
aegis_vivado/

# ===== Python =====
__pycache__/
*.pyc
.venv/
venv/

# ===== Generated data (regenerated on demand) =====
*.npy
*.pth

# Results - ignore generated plots, keep simulation logs
results/*.png
results/final_demo/
results/demo/
!results/simulation/
!results/simulation/*.log
!results/simulation/SUMMARY.txt
!results/.gitkeep

# ===== Traces directory =====
traces/*
!traces/.gitkeep

# ===== OS junk =====
.DS_Store
Thumbs.db
